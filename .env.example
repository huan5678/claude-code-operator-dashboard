# ---------- 必填 ----------

# 目標 Claude Code Channel 絕對路徑（含 .claude/, tasks/, memory/）
CHANNEL_PATH=/path/to/your/claude-code-channel

# Google OAuth Client ID（在 Google Cloud Console 建立 OAuth 2.0 Web Application
# 後從「Client ID」欄位複製。Authorized JavaScript origins 要填 TUNNEL_HOSTNAME
# 加上 http://localhost:5173 做開發）
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# 唯一允許登入的 Email（必須與 Google 帳號完全一致）
# ⚠️ Single-operator design：本系統假設只有一個 email。改 multi-user 前必須在
# code 層補上 resource-owner 檢查（詳見 auth-gate.js 的註解），否則任一 user
# 可看其他 user 的 terminal log / 改 SOUL.md / 殺其他 PTY session。
ALLOWED_EMAIL=you@example.com

# 自家 Session JWT 簽章密鑰，請用 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成
SESSION_SECRET=replace_me_with_a_strong_64_char_hex_secret

# ---------- 可選 ----------

# Express 服務 port
PORT=3000

# Cloudflare tunnel 對外 hostname（CSP 與 cookie domain 都會用到）
TUNNEL_HOSTNAME=codd.example.com

# Node 環境（production 會啟用 Secure cookie、CSP 嚴格模式等）
NODE_ENV=production

# SQLite 檔案位置（**絕對路徑**，MCP server 也會讀取同一個路徑）
KANBAN_DB_PATH=/path/to/2026-remote-claude-code-manager/apps/server/data/kanban.db

# Hook 寫 session status 的目錄（multi-session：每個 session 一個 file
# <session_id>.json）。channel CLI 會自動把這個值寫進 channel hook command 的 env。
# 舊版 STATUS_FILE_PATH 仍向下相容（會取 dirname 當作目錄）。
STATUS_DIR_PATH=/Users/you/.claude/codd-status

# Session 有效期（天）
SESSION_TTL_DAYS=7

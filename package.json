{
  "name": "claude-code-fancy-codd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/server",
    "apps/web",
    "apps/mcp"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm --workspace apps/server run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "start": "npm --workspace apps/server run start",
    "mcp": "npm --workspace apps/mcp run start",
    "tunnel": "cloudflared tunnel --config configs/cloudflared.yml run",
    "channel": "node scripts/channel-cli.js"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
